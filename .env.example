# Bot token from the Discord Developer Portal (Bot tab)
DISCORD_TOKEN=

# Your application's client ID (Developer Portal > General Information)
CLIENT_ID=

# Optional: a guild (server) ID. If set, slash commands are registered to this
# guild only, which updates instantly — ideal for development. Leave blank to
# register commands globally (can take up to an hour to propagate).
GUILD_ID=

# Anthropic API key (https://console.anthropic.com)
# `/gloss find` uses Claude as a conceptual reverse dictionary
ANTHROPIC_API_KEY=
